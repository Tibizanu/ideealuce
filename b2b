import React, { useState } from "react";
import { motion } from "framer-motion";
import { Building2, Factory, Home, ArrowRight, CheckCircle2, Send } from "lucide-react";
import { useToast } from "@/components/ui/use-toast";
import { base44 } from "@/api/base44Client";

const segments = [
  {
    icon: Building2,
    title: "Comercial & Retail",
    desc: "Iluminat profesional pentru magazine, birouri, hoteluri și spații comerciale. Soluții personalizate pentru a crea atmosfera perfectă.",
  },
  {
    icon: Factory,
    title: "Industrial",
    desc: "Corpuri de iluminat industrial robuste, tablouri electrice, cablaje și protecții. Eficiență maximă, conformitate garantată.",
  },
  {
    icon: Home,
    title: "Rezidențial",
    desc: "Proiecte complete de iluminat rezidențial — de la consultanță la instalare. Transformăm viziunea dvs. în realitate.",
  },
];

const benefits = [
  "Prețuri dedicate pentru parteneri și volume mari",
  "Consultanță tehnică pe întregul proiect",
  "Livrare rapidă din stocurile disponibile",
  "Soluții eficiente energetic certificate",
  "Personal de specialitate la dispoziția dvs.",
];

export default function B2BSection() {
  const { toast } = useToast();
  const [sending, setSending] = useState(false);
  const [form, setForm] = useState({
    name: "",
    company: "",
    email: "",
    phone: "",
    projectType: "",
    message: "",
  });

  const handleChange = (e) => {
    setForm({ ...form, [e.target.name]: e.target.value });
  };

  const handleSubmit = async (e) => {
    e.preventDefault();
    setSending(true);

    try {
      const emailBody = `
        <h2>Cerere Ofertă Nouă - Ideealuce by Braco SRL</h2>
        <p><strong>Nume:</strong> ${form.name}</p>
        <p><strong>Companie:</strong> ${form.company || "N/A"}</p>
        <p><strong>Email:</strong> ${form.email}</p>
        <p><strong>Telefon:</strong> ${form.phone}</p>
        <p><strong>Tip Proiect:</strong> ${form.projectType}</p>
        <p><strong>Descriere Proiect:</strong></p>
        <p>${form.message || "N/A"}</p>
      `;

      await base44.integrations.Core.SendEmail({
        to: "office@ideealuce.ro",
        subject: `Cerere ofertă nouă - ${form.name}${form.company ? " (" + form.company + ")" : ""}`,
        body: emailBody,
      });

      setSending(false);
      toast({
        title: "Cerere trimisă cu succes!",
        description: "Echipa noastră vă va contacta în cel mai scurt timp.",
      });
      setForm({ name: "", company: "", email: "", phone: "", projectType: "", message: "" });
    } catch (error) {
      setSending(false);
      toast({
        title: "Eroare",
        description: "A apărut o eroare. Vă rugăm încercați din nou sau sunați la 0233 226 178.",
        variant: "destructive",
      });
    }
  };

  return (
    <section id="b2b" className="relative overflow-hidden">
      {/* Background */}
      <div className="absolute inset-0">
        <img
          src="https://media.base44.com/images/public/6a3cf3e671f087abd061525a/77cab9b64_generated_52febcdc.png"
          alt="Proiect industrial de iluminat profesional"
          className="w-full h-full object-cover"
        />
        <div className="absolute inset-0 bg-filament/90" />
      </div>

      <div className="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 py-20 lg:py-28">
        {/* Header */}
        <motion.div
          initial={{ opacity: 0, y: 20 }}
          whileInView={{ opacity: 1, y: 0 }}
          viewport={{ once: true }}
          transition={{ duration: 0.6 }}
          className="text-center mb-16"
        >
          <p className="text-gold text-sm font-semibold tracking-[0.2em] uppercase mb-3">
            Soluții Profesionale
          </p>
          <h2 className="text-3xl lg:text-5xl font-bold text-bone tracking-tight mb-4">
            Partenerul Tău pentru Proiecte
          </h2>
          <p className="text-bone text-lg max-w-2xl mx-auto" style={{ lineHeight: 1.6 }}>
            Oferim soluții complete de iluminat și instalații electrice pentru
            companii, antreprenori și dezvoltatori imobiliari din toată regiunea Moldovei.
          </p>
        </motion.div>

        <div className="grid lg:grid-cols-2 gap-12 lg:gap-16">
          {/* Left: Segments & Benefits */}
          <div>
            <div className="space-y-6 mb-10">
              {segments.map((seg, i) => (
                <motion.div
                  key={seg.title}
                  initial={{ opacity: 0, x: -20 }}
                  whileInView={{ opacity: 1, x: 0 }}
                  viewport={{ once: true }}
                  transition={{ duration: 0.5, delay: i * 0.15 }}
                  className="flex gap-4 p-5 border border-bone/10 hover:border-gold/30 transition-colors group"
                >
                  <div className="flex-shrink-0 w-12 h-12 flex items-center justify-center border border-gold/30 group-hover:bg-gold/10 transition-colors">
                    <seg.icon size={22} className="text-gold" />
                  </div>
                  <div>
                    <h3 className="text-bone font-semibold text-lg mb-1">{seg.title}</h3>
                    <p className="text-bone text-sm" style={{ lineHeight: 1.6 }}>
                      {seg.desc}
                    </p>
                  </div>
                </motion.div>
              ))}
            </div>

            {/* Benefits */}
            <div className="space-y-3">
              {benefits.map((b) => (
                <div key={b} className="flex items-start gap-3">
                  <CheckCircle2 size={18} className="text-gold flex-shrink-0 mt-0.5" />
                  <span className="text-bone text-sm">{b}</span>
                </div>
              ))}
            </div>
          </div>

          {/* Right: Form */}
          <motion.div
            initial={{ opacity: 0, x: 20 }}
            whileInView={{ opacity: 1, x: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 0.6 }}
          >
            <div className="bg-bone/5 border border-bone/10 p-8 backdrop-blur-sm">
              <h3 className="text-bone font-bold text-xl mb-2">Solicită o Ofertă</h3>
              <p className="text-bone text-sm mb-6">
                Completează formularul și echipa noastră te va contacta cu o ofertă personalizată.
              </p>

              <form onSubmit={handleSubmit} className="space-y-4">
                <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <input
                    type="text"
                    name="name"
                    required
                    placeholder="Nume complet"
                    value={form.name}
                    onChange={handleChange}
                    className="w-full bg-transparent border border-bone/20 px-4 py-3 text-bone text-sm placeholder:text-bone/40 focus:border-gold focus:outline-none transition-colors min-h-[44px]"
                  />
                  <input
                    type="text"
                    name="company"
                    placeholder="Companie (opțional)"
                    value={form.company}
                    onChange={handleChange}
                    className="w-full bg-transparent border border-bone/20 px-4 py-3 text-bone text-sm placeholder:text-bone/40 focus:border-gold focus:outline-none transition-colors min-h-[44px]"
                  />
                </div>
                <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <input
                    type="email"
                    name="email"
                    required
                    placeholder="Email"
                    value={form.email}
                    onChange={handleChange}
                    className="w-full bg-transparent border border-bone/20 px-4 py-3 text-bone text-sm placeholder:text-bone/40 focus:border-gold focus:outline-none transition-colors min-h-[44px]"
                  />
                  <input
                    type="tel"
                    name="phone"
                    required
                    placeholder="Telefon"
                    value={form.phone}
                    onChange={handleChange}
                    className="w-full bg-transparent border border-bone/20 px-4 py-3 text-bone text-sm placeholder:text-bone/40 focus:border-gold focus:outline-none transition-colors min-h-[44px]"
                  />
                </div>
                <select
                  name="projectType"
                  required
                  value={form.projectType}
                  onChange={handleChange}
                  className="w-full bg-transparent border border-bone/20 px-4 py-3 text-bone text-sm focus:border-gold focus:outline-none transition-colors min-h-[44px] appearance-none"
                >
                  <option value="" className="bg-filament">Tip Proiect</option>
                  <option value="comercial" className="bg-filament">Comercial & Retail</option>
                  <option value="industrial" className="bg-filament">Industrial</option>
                  <option value="rezidential" className="bg-filament">Rezidențial</option>
                  <option value="altul" className="bg-filament">Alt tip de proiect</option>
                </select>
                <textarea
                  name="message"
                  rows={4}
                  placeholder="Descrieți pe scurt proiectul dvs..."
                  value={form.message}
                  onChange={handleChange}
                  className="w-full bg-transparent border border-bone/20 px-4 py-3 text-bone text-sm placeholder:text-bone/40 focus:border-gold focus:outline-none transition-colors resize-none"
                />
                <button
                  type="submit"
                  disabled={sending}
                  className="w-full bg-gold text-white py-3.5 font-semibold tracking-wide hover:bg-amber-600 transition-colors flex items-center justify-center gap-2 min-h-[44px] disabled:opacity-60"
                >
                  {sending ? (
                    "Se trimite..."
                  ) : (
                    <>
                      Trimite Cererea
                      <Send size={16} />
                    </>
                  )}
                </button>
              </form>
            </div>
          </motion.div>
        </div>
      </div>
    </section>
  );
}