import React, { useState, useEffect } from "react";
import { motion, AnimatePresence } from "framer-motion";
import { X, ExternalLink, Loader2, Package } from "lucide-react";
import { base44 } from "@/api/base44Client";

export default function ProductDetailModal({ product, onClose }) {
  const [details, setDetails] = useState(null);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState(false);
  const [activeImage, setActiveImage] = useState(0);

  useEffect(() => {
    if (!product) return;

    setDetails(null);
    setError(false);
    setLoading(true);
    setActiveImage(0);

    const fetchDetails = async () => {
      try {
        const result = await base44.integrations.Core.InvokeLLM({
          prompt: `Vizitează pagina produsului de la acest URL: ${product.url}

Extrage următoarele informații despre produs:
1. O descriere completă și detaliată a produsului (caracteristici, utilizări, avantaje)
2. Specificațiile tehnice complete (tensiune, curent, putere, dimensiuni, material, etc.)
3. URL-urile imaginilor produsului (toate imaginile disponibile)

Răspunde în limba română. Dacă pagina nu poate fi accesată, folosește informațiile disponibile din denumirea produsului: "${product.name}".`,
          add_context_from_internet: true,
          model: "gemini_3_flash",
          response_json_schema: {
            type: "object",
            properties: {
              description: {
                type: "string",
                description: "Descrierea completă a produsului în limba română"
              },
              specifications: {
                type: "array",
                items: {
                  type: "object",
                  properties: {
                    label: { type: "string" },
                    value: { type: "string" }
                  }
                }
              },
              images: {
                type: "array",
                items: { type: "string" },
                description: "URL-urile imaginilor produsului"
              }
            }
          }
        });

        setDetails(result);
        setLoading(false);
      } catch (err) {
        setError(true);
        setLoading(false);
      }
    };

    fetchDetails();
  }, [product]);

  // Lock body scroll
  useEffect(() => {
    if (product) {
      document.body.style.overflow = "hidden";
    }
    return () => {
      document.body.style.overflow = "";
    };
  }, [product]);

  const allImages = details?.images?.length > 0 ? details.images : (product ? [product.image] : []);

  return (
    <AnimatePresence>
      {product && (
        <>
          {/* Backdrop */}
          <motion.div
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            onClick={onClose}
            className="fixed inset-0 bg-black/60 z-[60]"
          />

          {/* Modal */}
          <div className="fixed inset-0 z-[60] flex items-center justify-center p-4 pointer-events-none">
            <motion.div
              initial={{ opacity: 0, scale: 0.95, y: 20 }}
              animate={{ opacity: 1, scale: 1, y: 0 }}
              exit={{ opacity: 0, scale: 0.95, y: 20 }}
              transition={{ duration: 0.25 }}
              className="bg-bone w-full max-w-4xl max-h-[90vh] overflow-y-auto pointer-events-auto"
            >
              {/* Header */}
              <div className="sticky top-0 bg-bone z-10 flex items-center justify-between p-5 border-b border-filament/10">
                <p className="text-gold text-xs font-semibold tracking-[0.15em] uppercase">Detalii Produs</p>
                <button
                  onClick={onClose}
                  className="min-w-[44px] min-h-[44px] flex items-center justify-center text-filament hover:text-gold transition-colors"
                  aria-label="Închide"
                >
                  <X size={22} />
                </button>
              </div>

              {loading ? (
                <div className="flex flex-col items-center justify-center py-24">
                  <Loader2 size={40} className="text-gold animate-spin mb-4" />
                  <p className="text-slate-atm text-sm">Se încarcă detaliile produsului...</p>
                </div>
              ) : error ? (
                <div className="flex flex-col items-center justify-center py-16 px-6 text-center">
                  <Package size={48} className="text-filament/20 mb-4" />
                  <p className="text-filament font-medium mb-2">{product.name}</p>
                  <p className="text-slate-atm text-sm mb-6" style={{ lineHeight: 1.6 }}>
                    Nu am putut încărca detaliile complete. Puteți vedea produsul direct pe site-ul furnizorului.
                  </p>
                  <a
                    href={product.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    className="inline-flex items-center gap-2 bg-gold text-white px-6 py-3 text-sm font-semibold hover:bg-amber-600 transition-colors min-h-[44px]"
                  >
                    Vezi pe site-ul furnizorului
                    <ExternalLink size={14} />
                  </a>
                </div>
              ) : details ? (
                <div className="p-5 lg:p-8">
                  {/* Image gallery */}
                  <div className="mb-6">
                    <div className="aspect-square max-w-md mx-auto overflow-hidden bg-white mb-3">
                      <img
                        src={allImages[activeImage] || product.image}
                        alt={product.name}
                        className="w-full h-full object-contain"
                        onError={(e) => { e.target.src = product.image; }}
                      />
                    </div>
                    {allImages.length > 1 && (
                      <div className="flex justify-center gap-2 flex-wrap">
                        {allImages.slice(0, 6).map((img, idx) => (
                          <button
                            key={idx}
                            onClick={() => setActiveImage(idx)}
                            className={`w-16 h-16 overflow-hidden border-2 transition-colors ${
                              activeImage === idx ? "border-gold" : "border-transparent hover:border-filament/20"
                            }`}
                          >
                            <img src={img} alt="" className="w-full h-full object-contain" onError={(e) => { e.target.style.display = 'none'; }} />
                          </button>
                        ))}
                      </div>
                    )}
                  </div>

                  {/* Product name */}
                  <h3 className="text-filament text-xl lg:text-2xl font-bold tracking-tight mb-4">
                    {product.name}
                  </h3>

                  {/* Description */}
                  {details.description && (
                    <div className="mb-6">
                      <h4 className="text-gold text-sm font-semibold tracking-wide uppercase mb-2">Descriere</h4>
                      <p className="text-slate-atm text-sm" style={{ lineHeight: 1.7 }}>
                        {details.description}
                      </p>
                    </div>
                  )}

                  {/* Specifications */}
                  {details.specifications && details.specifications.length > 0 && (
                    <div className="mb-6">
                      <h4 className="text-gold text-sm font-semibold tracking-wide uppercase mb-3">Specificații Tehnice</h4>
                      <div className="bg-white border border-filament/10">
                        {details.specifications.map((spec, idx) => (
                          <div
                            key={idx}
                            className={`flex justify-between gap-4 px-4 py-2.5 text-sm ${
                              idx % 2 === 0 ? "bg-bone" : "bg-white"
                            }`}
                          >
                            <span className="text-slate-atm font-medium flex-shrink-0">{spec.label}</span>
                            <span className="text-filament text-right">{spec.value}</span>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}


                </div>
              ) : null}
            </motion.div>
          </div>
        </>
      )}
    </AnimatePresence>
  );
}